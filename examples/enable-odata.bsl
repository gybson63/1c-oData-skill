// Включить объекты конфигурации в стандартный OData-интерфейс
//
// Код нужно выполнить в одном из контекстов:
//   - Сервер (Сервер)
//   - Толстый клиент (ТолстыйКлиент)
//   - Внешнее соединение (ВнешнееСоединение)
//   - Интеграция (Интеграция)
//
// После выполнения объект становится доступен по адресу:
//   GET http://host/base/odata/standard.odata/Catalog_ИмяСправочника

// -------------------------------------------------------
// Вариант 1: Включить конкретный объект
// -------------------------------------------------------

МассивОбъектов = Новый Массив();
МассивОбъектов.Добавить(Метаданные.Справочники.ИмяСправочника);
УстановитьСоставСтандартногоИнтерфейсаOData(МассивОбъектов);

// -------------------------------------------------------
// Вариант 2: Включить несколько объектов разных типов
// -------------------------------------------------------

МассивОбъектов = Новый Массив();

// Справочники
МассивОбъектов.Добавить(Метаданные.Справочники.Сотрудники);
МассивОбъектов.Добавить(Метаданные.Справочники.ФизическиеЛица);

// Документы
МассивОбъектов.Добавить(Метаданные.Документы.Отпуск);

// Регистры сведений
МассивОбъектов.Добавить(Метаданные.РегистрыСведений.ДанныеСотрудника);

УстановитьСоставСтандартногоИнтерфейсаOData(МассивОбъектов);

// -------------------------------------------------------
// Вариант 3: Включить все справочники
// (осторожно — может нагрузить сервер при первом обращении)
// -------------------------------------------------------

МассивОбъектов = Новый Массив();

Для Каждого Справочник Из Метаданные.Справочники Цикл
    МассивОбъектов.Добавить(Справочник);
КонецЦикла;

УстановитьСоставСтандартногоИнтерфейсаOData(МассивОбъектов);


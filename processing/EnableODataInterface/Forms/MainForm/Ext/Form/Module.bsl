#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ЗаполнитьДеревоОбъектов();
	// Развернуть все группы верхнего уровня
	Для Каждого Группа Из ДеревоОбъектов.ПолучитьЭлементы() Цикл
		Элементы.ДеревоОбъектов.Развернуть(Группа.ПолучитьИдентификатор(), Ложь);
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоОбъектов

// При изменении флажка: если строка — группа, транслировать значение на все дочерние.
&НаКлиенте
Процедура ДеревоОбъектовВключенПриИзменении(Элемент)
	ТекущиеДанные = Элементы.ДеревоОбъектов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если ТекущиеДанные.ЭтоГруппа Тогда
		Для Каждого Строка Из ТекущиеДанные.ПолучитьЭлементы() Цикл
			Строка.Включен = ТекущиеДанные.Включен;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Включить(Команда)
	ТекстСостояния = "Выполняется...";
	ТекстСостояния = УстановитьСоставODataНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьВсе(Команда)
	УстановитьВсеФлажки(Истина);
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсе(Команда)
	УстановитьВсеФлажки(Ложь);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Читает текущий состав OData и заполняет дерево на сервере.
// Использует ДеревоЗначений через РеквизитФормыВЗначение / ЗначениеВРеквизитФормы.
&НаСервере
Процедура ЗаполнитьДеревоОбъектов()

	ТекущийСостав = ПолучитьСоставСтандартногоИнтерфейсаOData();

	ОпубликованныеОбъекты = Новый Соответствие;
	Для Каждого ОбъектМД Из ТекущийСостав Цикл
		ОпубликованныеОбъекты.Вставить(ОбъектМД.ПолноеИмя(), Истина);
	КонецЦикла;

	Дерево = РеквизитФормыВЗначение("ДеревоОбъектов", Тип("ДеревоЗначений"));
	Дерево.Строки.Очистить();

	ДобавитьГруппуВДерево(Дерево, "Справочники",          Метаданные.Справочники,        ОпубликованныеОбъекты);
	ДобавитьГруппуВДерево(Дерево, "Документы",            Метаданные.Документы,          ОпубликованныеОбъекты);
	ДобавитьГруппуВДерево(Дерево, "Регистры сведений",    Метаданные.РегистрыСведений,   ОпубликованныеОбъекты);
	ДобавитьГруппуВДерево(Дерево, "Регистры накопления",  Метаданные.РегистрыНакопления, ОпубликованныеОбъекты);
	ДобавитьГруппуВДерево(Дерево, "Регистры расчета",     Метаданные.РегистрыРасчета,    ОпубликованныеОбъекты);
	ДобавитьГруппуВДерево(Дерево, "Планы видов расчета",  Метаданные.ПланыВидовРасчета,  ОпубликованныеОбъекты);
	ДобавитьГруппуВДерево(Дерево, "Перечисления",         Метаданные.Перечисления,       ОпубликованныеОбъекты);
	ДобавитьГруппуВДерево(Дерево, "Планы обмена",         Метаданные.ПланыОбмена,        ОпубликованныеОбъекты);

	ЗначениеВРеквизитФормы(Дерево, "ДеревоОбъектов");

	КоличествоОпубликовано = ТекущийСостав.Количество();
	Если КоличествоОпубликовано > 0 Тогда
		ТекстСостояния = СтрШаблон("Текущий состав загружен. Опубликовано объектов: %1.", КоличествоОпубликовано);
	Иначе
		ТекстСостояния = "OData-интерфейс пока не настроен.";
	КонецЕсли;

КонецПроцедуры

// Добавляет группу с дочерними строками объектов в ДеревоЗначений.
// Флажок группы = Истина только если все дочерние включены.
&НаСервере
Процедура ДобавитьГруппуВДерево(Дерево, НаименованиеГруппы, КоллекцияМД, ОпубликованныеОбъекты)

	Если КоллекцияМД.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	Группа              = Дерево.Строки.Добавить();
	Группа.Наименование = НаименованиеГруппы;
	Группа.ЭтоГруппа    = Истина;

	КоличествоВключено = 0;
	Для Каждого ОбъектМД Из КоллекцияМД Цикл
		Строка              = Группа.Строки.Добавить();
		Строка.Наименование = ОбъектМД.Синоним;
		Строка.ОбъектМД     = ОбъектМД.ПолноеИмя();
		Строка.ЭтоГруппа    = Ложь;
		Строка.Включен      = ОпубликованныеОбъекты[ОбъектМД.ПолноеИмя()] = Истина;
		Если Строка.Включен Тогда
			КоличествоВключено = КоличествоВключено + 1;
		КонецЕсли;
	КонецЦикла;

	// Группа отмечена только если все дочерние включены
	Группа.Включен = (КоличествоВключено = КоллекцияМД.Количество());

КонецПроцедуры

// Собирает отмеченные объекты из дерева и устанавливает состав OData.
&НаСервере
Функция УстановитьСоставODataНаСервере()

	НовыйМассив = Новый Массив;

	Дерево = РеквизитФормыВЗначение("ДеревоОбъектов", Тип("ДеревоЗначений"));
	Для Каждого Группа Из Дерево.Строки Цикл
		Для Каждого Строка Из Группа.Строки Цикл
			Если Строка.Включен Тогда
				ОбъектМД = Метаданные.НайтиПоПолномуИмени(Строка.ОбъектМД);
				Если ОбъектМД <> Неопределено Тогда
					НовыйМассив.Добавить(ОбъектМД);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	УстановитьСоставСтандартногоИнтерфейсаOData(НовыйМассив);

	Возврат СтрШаблон("Готово. Опубликовано объектов: %1.", НовыйМассив.Количество());

КонецФункции

// Выставляет флажок "Включен" для всех групп и дочерних строк.
&НаКлиенте
Процедура УстановитьВсеФлажки(Значение)
	Для Каждого Группа Из ДеревоОбъектов.ПолучитьЭлементы() Цикл
		Группа.Включен = Значение;
		Для Каждого Строка Из Группа.ПолучитьЭлементы() Цикл
			Строка.Включен = Значение;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

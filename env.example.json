{
  "profiles": {
    "default": {
      "telegram_token": "TELEGRAM_BOT_TOKEN",

      "ai_api_key": "OPENAI_API_KEY",
      "ai_base_url": "https://api.openai.com/v1",
      "ai_model": "gpt-4o-mini",
      "ai_rpm": 20,
      "ai_temperature": 0.1,
      "ai_temperature_step2": 0.3,

      "history_max_turns": 10,

      "history": {
        "max_turns": 10,
        "max_messages": 100,
        "trim_to": 60,
        "persist_dir": ".cache/histories"
      },

      "telegram": {
        "message_max_length": 4000,
        "connect_timeout": 30,
        "read_timeout": 120,
        "write_timeout": 60,
        "retry_count": 2,
        "retry_delay": 2,
        "polling_restart_delay": 5
      },

      "odata": {
        "default_top": 20,
        "max_top": 50,
        "request_timeout": 60,
        "max_url_length": 2000,
        "max_expand_fields": 15,
        "max_sample_records": 30,
        "max_data_length": 8000,
        "metadata_cache_seconds": 86400
      },

      "agents": {
        "odata": {
          "type": "odata",
          "odata_url": "http://localhost/YourBaseName/odata/standard.odata",
          "odata_user": "Администратор",
          "odata_password": "пароль",

          "mcp_servers": {
            "odata": {
              "command": "python",
              "args": ["mcp_servers/odata_server.py"],
              "env": {
                "ODATA_URL": "http://localhost/YourBaseName/odata/standard.odata",
                "ODATA_USER": "Администратор",
                "ODATA_PASSWORD": "пароль",
                "ODATA_TIMEOUT": "30",
                "ODATA_CONNECT_TIMEOUT": "10"
              }
            }
          }
        }
      },

      "formatter": {
        "enabled": true,
        "formatter_model": "gpt-4o-mini",
        "temperature": 0.2
      },

      "ai_pricing": {
        "input_per_1m": 0.15,
        "output_per_1m": 0.60
      }
    }
  }
}